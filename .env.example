# ── Cyber Neuro OS — environment template ──────────────────────────────
# Copy to `.env.local` (gitignored) for local dev, or set in Vercel project settings.
# NEVER commit real secrets. `.env` and `.env.*` are gitignored (except this file).

# ── Server-only secrets (Vercel env / .env.local) ──────────────────────
# Alibaba DashScope (OpenAI-compatible) API key used by /api/chat.
DASHSCOPE_API_KEY=

# Sanity write token — ONLY for local migration scripts (scripts/migrateContent.ts).
# Never expose to the client bundle.
SANITY_AUTH_TOKEN=

# Comma-separated origins allowed to call /api/chat. Leave empty to allow same-origin
# + *.vercel.app previews only. Example: https://boyangjiao.xyz,https://www.boyangjiao.xyz
ALLOWED_ORIGINS=

# Optional outbound HTTP proxy for local dev (used by vite.config.ts apiProxy).
PROXY_URL=

# Generative UI (Borvis "show your work"). Set to 1 to let /api/chat attach the
# render_works tool so Borvis can render project cards/grids. Off (unset) = the
# original text-only chat, unchanged. Requires a restart of `npm run dev` locally.
GENUI_ENABLED=

# ── AI model overrides (Borvis agent). Defaults in code target the production
#    Coding-Plan endpoint; a standard Bailian key should use the values below. ──
# LLM (/api/chat): standard compatible-mode endpoint + a fast model.
CHAT_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# CHAT_MODEL = fast/base tier (casual chat). CHAT_MODEL_STRONG = strong tier used
# automatically for work-related or complex turns (and required for render_works tool
# calling — the fast model won't call tools reliably). Leave STRONG empty to disable
# routing (always use CHAT_MODEL). Restart `npm run dev` after changing either.
CHAT_MODEL=qwen-turbo
CHAT_MODEL_STRONG=qwen-plus
# TTS (/api/tts): Qwen-TTS; pick a voice from the Bailian voice list (Kai, Cherry…).
TTS_MODEL=qwen3-tts-flash
TTS_VOICE=Kai
# ASR (/api/asr): Qwen speech recognition.
ASR_MODEL=qwen3-asr-flash

# ── Client-exposed (VITE_ prefix — these ship in the bundle, keep non-secret) ──
VITE_SANITY_PROJECT_ID=argneoi8
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01
VITE_SANITY_STUDIO_URL=http://localhost:3333
