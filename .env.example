# ── Cyber Neuro OS — environment template ──────────────────────────────
# Copy to `.env.local` (gitignored) for local dev, or set in Vercel project settings.
# NEVER commit real secrets. `.env` and `.env.*` are gitignored (except this file).

# ── Server-only secrets (Vercel env / .env.local) ──────────────────────
# Alibaba DashScope (OpenAI-compatible) API key used by /api/chat.
DASHSCOPE_API_KEY=

# Sanity write token — ONLY for local migration scripts (scripts/migrateContent.ts).
# Never expose to the client bundle.
SANITY_AUTH_TOKEN=

# Comma-separated origins allowed to call /api/chat. Leave empty to allow same-origin
# + *.vercel.app previews only. Example: https://boyangjiao.xyz,https://www.boyangjiao.xyz
ALLOWED_ORIGINS=

# Optional outbound HTTP proxy for local dev (used by vite.config.ts apiProxy).
PROXY_URL=

# ── Client-exposed (VITE_ prefix — these ship in the bundle, keep non-secret) ──
VITE_SANITY_PROJECT_ID=argneoi8
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01
VITE_SANITY_STUDIO_URL=http://localhost:3333
